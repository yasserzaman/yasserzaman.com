# Server-side SMTP / email settings for the contact API.
# Copy to a local `.env` for development, and configure the same values
# in your Vercel project settings as Environment Variables.

EMAIL_HOST=smtp.zoho.in
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=info@altajtours.com
EMAIL_PASS=your_smtp_password_here
EMAIL_FROM="Al-Taj Tours <info@altajtours.com>"
EMAIL_TO=your_inbox@example.com

# --- AI assistant chatbot ---
# The chatbot picks a provider automatically: Groq if a Groq key is set,
# otherwise Gemini. Set ONE of them. The Vite build injects the key into the
# client from either the plain or VITE_-prefixed name.
#
# NOTE: whichever key you use is PUBLIC — it ships in the built JavaScript. Use a
# dedicated key and rotate/lock it down if abused.

# Option A — Groq (recommended: free tier, NO credit card required).
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Option B — Google Gemini. A key from aistudio.google.com/apikey ("AQ." or
# "AIza" both work). Requires BILLING enabled on the key's project, or the free
# tier returns HTTP 429. Lock it to the "Generative Language API" + your domain.
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Chatbot lead notifications reuse the EMAIL_* settings above via /api/contact.
