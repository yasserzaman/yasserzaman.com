# VITE_FORMSPREE_FORM_ID: Formspree form endpoint ID that powers the Contact
# section's submission pipeline (see src/components/Contact.tsx).
# 1. Create a free form at https://formspree.io
# 2. Copy the ID from your form's endpoint: https://formspree.io/f/<THIS PART>
# 3. Set it here for local dev, and as an environment variable in your
#    Vercel project settings for production.
VITE_FORMSPREE_FORM_ID="your_form_id_here"
